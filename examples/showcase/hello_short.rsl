// hello_short.rsl — Short form and expression body functions

// Short expression-body function
fn double(x: i32) => i32 { x * 2 }
fn square(x: f64) => f64 { x * x }
fn greet(name: str) => void { @print("Hello, {}!", name) }

fn main() => i32 {
    @print("Hello, World!")
    @print("double(5) = {}", double(5))
    @print("square(3.0) = {}", square(3.0))
    greet("R#")
    0
}

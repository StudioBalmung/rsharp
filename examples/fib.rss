-- examples/fib.rss
-- Fibonacci - demonstrates recursive functions, match, comptime

-- Recursive (naive, for illustration)
fn fib_rec(n: u32) => u64 {
    match n {
        0 => 0,
        1 => 1,
        _ => fib_rec(n - 1) + fib_rec(n - 2),
    }
}

-- Iterative (efficient)
fn fib(n: u32) => u64 {
    if n <= 1 { return n }
    var a: u64 = 0
    var b: u64 = 1
    for _ in 2..=n {
        let tmp = a + b
        a = b
        b = tmp
    }
    b
}

-- Comptime fibonacci (computed at compile time, zero runtime cost)
fn fib_comptime(comptime n: u32) => u64 {
    comptime {
        if n <= 1 { n }
        else { fib_comptime(n - 1) + fib_comptime(n - 2) }
    }
}

fn main() => i32 {
    -- Print first 15 fibonacci numbers
    for i in 0..15 {
        @print("fib({}) = {}", i, fib(i))
    }

    -- Comptime: resolved entirely at compile time
    let val = fib_comptime(30)
    @print("fib(30) [comptime] = {}", val)

    0
}

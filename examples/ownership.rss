-- examples/ownership.rss
-- R# Memory Safety Examples
-- Demonstrates: move semantics, borrowing, arena allocation, defer

-- ─── Move semantics ───────────────────────────────────────────────

struct Buffer {
    data: []u8,
    len:  usize,
}

fn consume(buf: Buffer) -> void {
    @print("consumed {} bytes", buf.len)
    -- buf.data is freed here (ownership ends)
}

fn move_demo() -> void {
    let buf = Buffer { data: [0u8; 64], len = 64 }
    consume(buf)   -- buf is MOVED into consume
    -- @print("{}", buf.len)  -- ERROR: use after move (caught at compile time)
    --   error: 'buf' was moved into 'consume' on line above
    --   note: 'Buffer' does not implement 'Copy'
    --   help: if you meant to copy, derive Copy: struct Buffer derives Copy { ... }
}

-- ─── Borrowing ───────────────────────────────────────────────────

fn borrow_read(buf: []u8) -> usize {
    -- Takes a shared borrow - buf.data is NOT freed
    var count: usize = 0
    for byte in buf { if byte != 0 { count += 1 } }
    count
}

fn borrow_write(buf: []u8) => void {
    -- Takes a mutable borrow
    for i in 0..buf.len {
        buf[i] = 0
    }
}

fn borrow_demo() => void {
    var data = [1u8, 2u8, 3u8, 4u8]
    let nonzero = borrow_read(data)  -- shared borrow, data still valid
    borrow_write(data)               -- mutable borrow, data is zeroed
    @print("non-zero bytes: {}", nonzero)
}

-- ─── Arena allocation ─────────────────────────────────────────────

fn arena_demo() => void {
    let arena = Arena.init(1024 * 64)   -- 64 KB scratch arena
    defer arena.deinit()

    -- Allocate into the arena - all freed when arena goes out of scope
    let names = arena.alloc([]u8, 16)
    names[0] = "Aether"
    names[1] = "Balmung"

    @print("first name: {}", names[0])
    -- arena.deinit() called automatically by defer
}

-- ─── Result and defer ────────────────────────────────────────────

enum IoError {
    NotFound  { path: []u8 },
    PermDenied,
    UnexpectedEof,
}

fn read_file(path: []u8) => Result<[]u8, IoError> {
    let fd = try fs.open(path)
    defer fd.close()                    -- always runs, even on early return

    let data = try fd.read_all()
    data
}

fn main() => i32 {
    move_demo()
    borrow_demo()
    arena_demo()

    let result = read_file("config.rss") catch |e| {
        match e {
            .NotFound { path } => @print("file not found: {}", path),
            .PermDenied        => @print("permission denied"),
            .UnexpectedEof     => @print("file truncated"),
        }
        return 1
    }

    @print("read {} bytes", result.len)
    0
}
